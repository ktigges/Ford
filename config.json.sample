{
  "environment": "development",
  "port": 8443,
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "lightning",
    "user": "lightning",
    "password": "CHANGE_ME"
  },
  "logging": {
    "level": "INFO",
    "log_sql": false
  },
  "collector": {
    "default_poll_interval_sec": 60,
    "max_consecutive_failures": 5
  },
  "ssl": {
    "enabled": true,
    "cert": "/path/to/server.crt",
    "key": "/path/to/server.key"
  },
  "external_id": {
    "enabled": true,
    "client_id": "CHANGE_ME_APP_ID",
    "client_secret": "CHANGE_ME_CLIENT_SECRET",
    "redirect_uri": "https://your-hostname:8443/oauth",
    "scope": "openid profile email",
    "authority": "https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0",
    "metadata_url": "",
    "allowed_groups": [
      "YOUR_GROUP_OBJECT_ID"
    ],
    "allowed_group_names": [
      "MLLightning"
    ]
  }
}
