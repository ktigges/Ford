{
  "environment": "development",
  "port": 8443,
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "lightning",
    "user": "lightning",
    "password": "CHANGE_ME"
  },
  "logging": {
    "level": "INFO",
    "log_sql": false
  },
  "collector": {
    "default_poll_interval_sec": 60,
    "max_consecutive_failures": 5
  },
  "ssl": {
    "enabled": true,
    "cert": "/path/to/server.crt",
    "key": "/path/to/server.key"
  },
  "external_id": {
    "enabled": true,
    "client_id": "CHANGE_ME_APP_ID",
    "client_secret": "CHANGE_ME_CLIENT_SECRET",
    "redirect_uri": "https://your-hostname/oidc/callback",
    "scope": "openid profile email offline_access",
    "authority": "https://yourtenant.ciamlogin.com/YOUR_TENANT_ID",
    "metadata_url": "https://yourtenant.ciamlogin.com/YOUR_TENANT_ID/v2.0/.well-known/openid-configuration",
    "allowed_tenants": [
      "YOUR_TENANT_ID"
    ],
    "consent_authority": "https://login.microsoftonline.com",
    "allowed_groups": [],
    "allowed_group_names": [
      "YOUR_ROLE_GUID"
    ]
  }
}
