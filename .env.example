# Lightning - Environment Configuration Template
# Copy this to .env and fill in with your actual values
# .env is gitignored and should never be committed

# ============================================================================
# REQUIRED: Flask Session Secret Key
# ============================================================================
# Generate a new key with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# This MUST be set before running the application
LIGHTNING_SECRET_KEY=your-secure-secret-key-here

# ============================================================================
# OPTIONAL: Local Auth Configuration
# ============================================================================
# Store client metadata in database (for audit trails). Defaults to 0 (false)
# LIGHTNING_LOCAL_AUTH_STORE_CLIENT_META=0

# Session absolute timeout in hours. Defaults to 8 hours
# LIGHTNING_LOCAL_AUTH_ABSOLUTE_TIMEOUT_HOURS=8

# Session idle timeout in minutes. Defaults to 30 minutes
# LIGHTNING_LOCAL_AUTH_IDLE_TIMEOUT_MINUTES=30

# ============================================================================
# OPTIONAL: Third-Party API Keys
# ============================================================================
# Weather API key (OpenWeather). If not set, falls back to limited "demo" mode
# OPENWEATHER_API_KEY=your-openweather-api-key

# Google Maps API key (optional, only needed if using Google routing)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OpenRouteService API key (optional, only needed if using ORS routing)
# OPENROUTESERVICE_API_KEY=your-openrouteservice-api-key

# ============================================================================
# OPTIONAL: Session Storage
# ============================================================================
# Session storage backend. Options: 'cachelib', 'filesystem', etc. Defaults to 'cachelib'
# LIGHTNING_SESSION_TYPE=cachelib
